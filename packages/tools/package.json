{
  "name": "@hankit/tools",
  "version": "0.0.1",
  "imports": {
    "#/*": "./src/*"
  },
  "description": "Toolkits for Hanzi and Pinyin",
  "license": "MIT",
  "homepage": "https://github.com/pai-mn/paidou/tree/main/packages/tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pai-mn/paidou.git",
    "directory": "packages/tools"
  },
  "bugs": {
    "url": "https://github.com/pai-mn/paidou/issues"
  },
  "keywords": [
    "hanzi",
    "chinese",
    "chinese-character",
    "pinyin"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --target=node --format=esm --define import.meta.vitest=false --outfile=dist/index.mjs && bun build src/index.ts --target=node --format=cjs --define import.meta.vitest=false --outfile=dist/index.cjs && tsc -p tsconfig.json"
  },
  "devDependencies": {
    "pinyin-pro": "3.28.1"
  }
}
