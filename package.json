{
  "name": "paidou",
  "description": "A Genshin Impact Chinese Hanzi variation of Wordle - 派兜",
  "type": "module",
  "private": true,
  "imports": {
    "#/*": "./src/*"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web \"bun --watch src/server/index.ts\" \"vite --port 4444\"",
    "build": "vite build",
    "format": "prettier --write .",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "update": "TEST=true vite-node src/tools/update.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@iconify-json/ri": "1.2.10",
    "@tanstack/vue-query": "5.101.2",
    "@vueuse/core": "14.3.0",
    "canvas-confetti": "1.9.4",
    "csv-parse": "7.0.1",
    "hono": "4.12.30",
    "html-to-image": "1.11.13",
    "pinyin-pro": "3.28.1",
    "reka-ui": "2.10.1",
    "seedrandom": "3.0.5",
    "vue": "3.5.40"
  },
  "devDependencies": {
    "@iconify-json/carbon": "1.2.24",
    "@iconify-json/ep": "1.2.4",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/noto-v1": "1.2.5",
    "@types/bun": "1.3.14",
    "@types/canvas-confetti": "1.9.0",
    "@types/file-saver": "2.0.7",
    "@types/node": "26.1.1",
    "@types/seedrandom": "3.0.8",
    "@unocss/preset-mini": "66.7.5",
    "@unocss/reset": "66.7.5",
    "@vitejs/plugin-vue": "6.0.8",
    "@vue/test-utils": "2.4.11",
    "ansis": "4.3.1",
    "cheerio": "1.2.0",
    "concurrently": "10.0.3",
    "csv-stringify": "6.8.1",
    "file-saver": "2.0.5",
    "jsdom": "29.1.1",
    "ohmyfetch": "0.4.21",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "unocss": "66.7.5",
    "unplugin-auto-import": "21.0.0",
    "unplugin-vue-components": "32.1.0",
    "vite": "8.1.5",
    "vite-node": "6.0.0",
    "vitest": "4.1.10"
  }
}
